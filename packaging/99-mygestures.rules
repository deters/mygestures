# MyGestures udev rules
# This file is designed to ensure MyGestures can access input devices and simulate keystrokes securely.

# SECURE SETUP (Recommended): Restrict /dev/uinput to the 'input' group.
# This prevents unauthorized users/processes from injecting keyboard/mouse events.
# When mygestures is installed as Set-Group-ID (SGID) to the 'input' group, it is granted access.
KERNEL=="uinput", SUBSYSTEM=="misc", GROUP="input", MODE:="0660", OPTIONS+="static_node=uinput"

# Access to input devices (mice, touchpads, etc.) is allowed via the 'input' group.
# (Most distributions already make event/mouse nodes owned by root:input with mode 0660 or 0640)
SUBSYSTEM=="input", KERNEL=="event*", GROUP="input", MODE="0660"
SUBSYSTEM=="input", KERNEL=="mouse*", GROUP="input", MODE="0660"

# Note: If you prefer the STANDARD SETUP (allowing all user applications to capture inputs),
# you can comment out the lines above and uncomment the lines below:
# KERNEL=="uinput", SUBSYSTEM=="misc", MODE:="0666", OPTIONS+="static_node=uinput"
# SUBSYSTEM=="input", KERNEL=="event*", TAG+="uaccess"
# SUBSYSTEM=="input", KERNEL=="mouse*", TAG+="uaccess"
