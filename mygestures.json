{
  "contexts": [
    {
      "name": "Terminal windows",
      "windowclass": ".*(Term|term).*",
      "windowtitle": ".*",
      "gestures": [
        {
          "name": "Open new tab (Ctrl+Shift+T)",
          "movement": "0,0 100,0 50,0 50,100",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+T"}]
        },
        {
          "name": "Open new window (Ctrl+Shift+N)",
          "movement": "0,100 0,0 100,100 100,0",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+N"}]
        },
        {
          "name": "Copy (Ctrl+Shift+C)",
          "movement": "100,0 0,0 0,100 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+C"}]
        },
        {
          "name": "Paste (Ctrl+Shift+V)",
          "movement": "0,0 50,100 100,0",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+V"}]
        },
        {
          "name": "Close current tab (Ctrl+Shift+W)",
          "movement": "0,0 100,0 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+W"}]
        }
      ]
    },
    {
      "name": "All applications",
      "windowclass": ".*",
      "windowtitle": ".*",
      "gestures": [
        {
          "name": "Close window",
          "movement": "0,0 0,100 100,100",
          "actions": [{"action": "kill"}]
        },
        {
          "name": "Maximize window",
          "movement": "50,100 50,0",
          "actions": [{"action": "toggle-maximized"}]
        },
        {
          "name": "Iconify window",
          "movement": "50,0 50,100",
          "actions": [{"action": "iconify"}]
        },
        {
          "name": "Previous page (Alt+Left)",
          "movement": "100,50 0,50",
          "actions": [{"action": "keypress", "value": "Alt_L+Left"}]
        },
        {
          "name": "Next page (Alt+Right)",
          "movement": "0,50 100,50",
          "actions": [{"action": "keypress", "value": "Alt_L+Right"}]
        },
        {
          "name": "Copy (Ctrl+C)",
          "movement": "100,0 0,0 0,100 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+C"}]
        },
        {
          "name": "Paste (Ctrl+V)",
          "movement": "0,0 50,100 100,0",
          "actions": [{"action": "keypress", "value": "Control_L+V"}]
        },
        {
          "name": "New (Ctrl+N)",
          "movement": "0,100 0,0 100,100 100,0",
          "actions": [{"action": "keypress", "value": "Control_L+N"}]
        },
        {
          "name": "Open (Ctrl+O)",
          "movement": "50,0 0,50 50,100 100,50 50,0",
          "actions": [{"action": "keypress", "value": "Control_L+O"}]
        },
        {
          "name": "Print (Ctrl+P)",
          "movement": "0,100 0,0 100,0 100,50 0,50",
          "actions": [{"action": "keypress", "value": "Control_L+P"}]
        },
        {
          "name": "Save (Ctrl+S)",
          "movement": "100,0 0,0 0,50 100,50 100,100 0,100",
          "actions": [{"action": "keypress", "value": "Control_L+S"}]
        },
        {
          "name": "Escape",
          "movement": "50,100 50,0",
          "actions": [{"action": "keypress", "value": "Escape"}]
        },
        {
          "name": "New tab (Ctrl+T)",
          "movement": "0,0 100,0 50,0 50,100",
          "actions": [{"action": "keypress", "value": "Control_L+T"}]
        },
        {
          "name": "Close tab (Ctrl+W)",
          "movement": "0,0 100,0 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+W"}]
        },
        {
          "name": "Run default browser",
          "movement": "0,0 25,100 50,50 75,100 100,0",
          "actions": [{"action": "www", "value": ""}]
        },
        {
          "name": "Run gedit",
          "movement": "100,0 0,0 0,100 100,100 100,50 50,50",
          "actions": [{"action": "exec", "value": "gedit"}]
        },
        {
          "name": "Previous Tab",
          "movement": "100,100 0,0 0,100",
          "actions": [{"action": "keypress", "value": "Control_L+Shift_L+Tab"}]
        },
        {
          "name": "Next Tab",
          "movement": "0,100 100,0 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+Tab"}]
        }
      ]
    },
    {
      "name": "Chrome",
      "windowclass": "Google-chrome",
      "windowtitle": ".*",
      "gestures": [
        {
          "name": "Close tab (Ctrl+F4)",
          "movement": "0,0 100,0 100,100",
          "actions": [{"action": "keypress", "value": "Control_L+F4"}]
        }
      ]
    }
  ]
}
