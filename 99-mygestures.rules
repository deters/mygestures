# MyGestures udev rules
# This file is designed to ensure MyGestures can access the mouse and simulate keystrokes.

# Force /dev/uinput to be accessible by all users (required for keyboard emulation).
KERNEL=="uinput", SUBSYSTEM=="misc", MODE:="0666", OPTIONS+="static_node=uinput"

# Allow access to input devices (mice, touchpads, etc.) via session-aware uaccess.
# We DO NOT use MODE="0666" here because it breaks hypervisors like UTM.
SUBSYSTEM=="input", KERNEL=="event*", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="mouse*", TAG+="uaccess"

# Specific matches for modern input devices based on ID_INPUT
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT}=="1", TAG+="uaccess"
