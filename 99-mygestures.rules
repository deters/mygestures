# MyGestures udev rules
# This file is designed to ensure MyGestures can access the mouse and simulate keystrokes.

# Force /dev/uinput to be accessible by all users (required for keyboard emulation).
KERNEL=="uinput", SUBSYSTEM=="misc", MODE:="0666", OPTIONS+="static_node=uinput", TAG+="uaccess"

# Broad fallback: Grant access to ALL input event nodes
SUBSYSTEM=="input", KERNEL=="event*", MODE:="0666", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="mouse*", MODE:="0666", TAG+="uaccess"

# Specific matches for modern input devices based on ID_INPUT
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT}=="1", TAG+="uaccess", MODE:="0666"
