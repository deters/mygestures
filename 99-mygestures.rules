# MyGestures udev rules

# Allow all users to access uinput (for virtual keyboard/mouse emulation)
# We use a broad rule here because uinput is often outside the standard seat/session logic.
KERNEL=="uinput", SUBSYSTEM=="misc", OPTIONS+="static_node=uinput", MODE="0666"

# Allow the currently logged-in user to access input devices (for evdev capture)
# This uses 'uaccess' which is session-aware and safer for actual hardware devices.
SUBSYSTEM=="input", KERNEL=="event*", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="mouse*", TAG+="uaccess"

# Ensure touchpads and touchscreens are also accessible
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHPAD}=="1", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", TAG+="uaccess"
