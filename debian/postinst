#!/bin/sh
# postinst script for mygestures
#
# see: dh_installdeb(1)

set -e

case "$1" in
    configure)
        # Ensure the 'input' group exists
        getent group input >/dev/null || groupadd -r input || true

        # Reload udev rules to apply the new uinput rule immediately
        if [ -x /lib/udev/udevadm ] || [ -x /usr/bin/udevadm ]; then
            udevadm control --reload-rules || true
            udevadm trigger --attr-match=subsystem=misc || true
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
